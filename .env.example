# Copy this file to .env and fill in your values

# OpenRouter API key (required for all LLM calls)
OPENROUTER_API_KEY=sk-or-v1-...

# Model for answer generation (pick one)
MODEL_NAME=google/gemini-2.5-flash
# MODEL_NAME=deepseek/deepseek-chat-v3-0324
# MODEL_NAME=mistralai/mistral-nemo

# Model for evaluation (RAGAS, G-Eval, LLM judge)
# Use a capable model for reliable evaluation
EVAL_MODEL_NAME=google/gemini-2.5-flash

# Source key for legacy automated_evaluation.ipynb
# Options: "GRADE Book" or "PDFs"
SOURCE_KEY=GRADE Book
